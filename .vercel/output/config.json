{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_server-islands\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/_image\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/404\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/send-email\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/send-quote\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/contacto\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/ecommerce\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/integraciones\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/precios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/testimonios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		},
		{
			"src": "/.*",
			"dest": "_render",
			"status": 404
		}
	]
}