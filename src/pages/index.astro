---
import Layout from '../layouts/Layout.astro';
import ServicesItems from '../components/ServicesItems.astro';
import Hero from '../components/Hero.astro';
import DarkVeil from '../components/dark-veil/DarkVeil';
import SpeedInsights  from "@vercel/speed-insights/astro"
import Analytics from '@vercel/analytics/astro'
import TechLogos from '../components/TechLogos';
---

<style>
	/* Vercel-style Professional Section Dividers */

	/* Subtle gradient line divider */
	.section-divider-gradient {
		position: relative;
		padding: 0;
		margin: 0;
		min-height: 1px;
		contain: layout style paint;
	}

	.section-divider-gradient::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 1400px;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(76, 214, 192, 0.1) 15%,
			rgba(76, 214, 192, 0.2) 50%,
			rgba(76, 214, 192, 0.1) 85%,
			transparent 100%
		);
		will-change: auto;
	}

	/* Radial glow divider */
	.section-divider-glow {
		position: relative;
		padding-top: 1px;
		min-height: 120px;
		contain: layout style paint;
	}

	.section-divider-glow::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 800px;
		height: 120px;
		background: radial-gradient(
			ellipse at top,
			rgba(76, 214, 192, 0.08) 0%,
			rgba(76, 214, 192, 0.03) 30%,
			transparent 70%
		);
		pointer-events: none;
		will-change: auto;
	}

	/* Subtle border with glow */
	.section-divider-border {
		border-top: 1px solid rgba(255, 255, 255, 0.03);
		box-shadow:
			0 1px 0 rgba(76, 214, 192, 0.05),
			0 -1px 40px rgba(76, 214, 192, 0.02);
		min-height: 1px;
		contain: layout style paint;
	}

	/* Double line divider (ultra subtle) */
	.section-divider-double {
		position: relative;
		padding-top: 2px;
		min-height: 2px;
		contain: layout style paint;
	}

	.section-divider-double::before,
	.section-divider-double::after {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 1200px;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(255, 255, 255, 0.03) 20%,
			rgba(76, 214, 192, 0.08) 50%,
			rgba(255, 255, 255, 0.03) 80%,
			transparent 100%
		);
		will-change: auto;
	}

	.section-divider-double::before {
		top: 0;
	}

	.section-divider-double::after {
		top: 2px;
		opacity: 0.5;
	}

	/* Glow from bottom divider */
	.section-divider-glow-bottom {
		position: relative;
		padding-bottom: 1px;
		min-height: 100px;
		contain: layout style paint;
	}

	.section-divider-glow-bottom::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 600px;
		height: 100px;
		background: radial-gradient(
			ellipse at bottom,
			rgba(76, 214, 192, 0.06) 0%,
			rgba(9, 179, 151, 0.03) 40%,
			transparent 70%
		);
		pointer-events: none;
		will-change: auto;
	}

	/* Subtle background transition */
	.section-divider-bg-shift {
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(76, 214, 192, 0.008) 50%,
			transparent 100%
		);
		padding: 80px 0;
		contain: layout style;
	}

	/* Spotlight effect divider */
	.section-divider-spotlight {
		position: relative;
		min-height: 1px;
		contain: layout style paint;
	}

	.section-divider-spotlight::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 600px;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(76, 214, 192, 0.25) 50%,
			transparent 100%
		);
		box-shadow:
			0 0 20px rgba(76, 214, 192, 0.1),
			0 0 40px rgba(76, 214, 192, 0.05);
		will-change: auto;
	}

	/* Minimal dot pattern divider */
	.section-divider-dots {
		position: relative;
		padding: 20px 0;
		min-height: 40px;
		contain: layout style paint;
	}

	.section-divider-dots::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) translateZ(0);
		width: 100%;
		height: 1px;
		background-image: radial-gradient(
			circle,
			rgba(76, 214, 192, 0.2) 1px,
			transparent 1px
		);
		background-size: 8px 8px;
		background-position: center;
		background-repeat: repeat-x;
		opacity: 0.3;
		will-change: auto;
	}

	/* IA Badge glow effect */
	.ia-badge {
		background: radial-gradient(
			ellipse at center,
			rgba(76, 214, 192, 0.15) 0%,
			rgba(76, 214, 192, 0.05) 50%,
			transparent 70%
		);
		box-shadow:
			0 0 30px rgba(76, 214, 192, 0.3),
			0 0 60px rgba(76, 214, 192, 0.15),
			inset 0 0 20px rgba(76, 214, 192, 0.1);
		animation: iaGlow 2s ease-in-out infinite alternate;
	}

	@keyframes iaGlow {
		0% {
			box-shadow:
				0 0 20px rgba(76, 214, 192, 0.2),
				0 0 40px rgba(76, 214, 192, 0.1),
				inset 0 0 15px rgba(76, 214, 192, 0.08);
		}
		100% {
			box-shadow:
				0 0 40px rgba(76, 214, 192, 0.4),
				0 0 80px rgba(76, 214, 192, 0.2),
				inset 0 0 25px rgba(76, 214, 192, 0.15);
		}
	}
</style>

<Layout
	title="Kreadium | Desarrollo Web Profesional en Chile - WordPress & Shopify"
	description="Agencia de desarrollo web en Santiago. Expertos en WordPress, Shopify y Next.js. Diseño web responsivo, SEO optimizado y soluciones e-commerce escalables."
	ogTitle="Kreadium | Desarrollo Web Profesional en Chile - WordPress & Shopify"
	ogDescription="Agencia de desarrollo web en Santiago. Expertos en WordPress, Shopify y Next.js. Diseño web responsivo, SEO optimizado y soluciones e-commerce escalables."
	canonical="/"
>
	<!-- Vista desktop: Galaxy Hero -->
	<div id="inicio" class="hidden md:block relative w-full md:h-[400px] lg:h-[600px] h-[400px] overflow-hidden scroll-mt-20 md:scroll-mt-24">
		<DarkVeil client:only
		hueShift={54}
		noiseIntensity={0.15}
		scanlineIntensity={0.3}
		speed={0.5}
		scanlineFrequency={60}
		warpAmount={0.08}
		resolutionScale={1}
		/>
		<div class="absolute inset-0 z-10">
			<Hero />
		</div>

		<!-- Layer 4 (top-most): Overlay gradient fade to black -->
		<div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-transparent via-transparent to-black/100 z-20"></div>
	</div>

	<!-- Vista mobile: Hero sin Galaxy -->
	<div class="block md:hidden relative w-full md:h-[400px] lg:h-[600px] h-[400px] overflow-hidden bg-gradient-to-b from-gray-900 via-slate-800 to-black scroll-mt-20 md:scroll-mt-24">
		 <Hero />
		<div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-transparent via-transparent to-black/100"></div>
	</div>

	<!-- Tech Logos Section -->
	<div class="section-divider-glow-bottom">
		<div class="container mx-auto max-w-7xl">
			<TechLogos client:only />
		</div>
	</div>

	<!-- Glow from bottom divider -->
	<div class="section-divider-glow-bottom"></div>

	<!-- AI Integration Section -->
	<div class="section-divider-spotlight"></div>
	<section id="inteligencia-artificial" class="relative py-20 md:py-32 overflow-hidden scroll-mt-20 md:scroll-mt-24">
		<!-- Background ambient glow -->
		<div class="absolute inset-0 pointer-events-none">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-teal-400/[0.04] rounded-full blur-3xl"></div>
			<div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] bg-teal-500/[0.03] rounded-full blur-3xl"></div>
		</div>

		<div class="container mx-auto max-w-7xl px-4 relative z-10">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-block mb-6">
					<span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs md:text-sm font-medium"
						style="background: rgba(76, 214, 192, 0.1); border: 1px solid rgba(76, 214, 192, 0.2); color: rgba(76, 214, 192, 0.9);">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
						</svg>
						Inteligencia Artificial Aplicada
					</span>
				</div>
				<h2 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
					Soluciones que piensan <span class="text-teal-300">con tu negocio</span>
				</h2>
				<p class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto">
					Integramos IA directamente en el desarrollo de tu sitio o aplicación para automatizar procesos, personalizar experiencias y generar resultados medibles.
				</p>
			</div>

			<!-- Main feature highlight -->
			<div class="rounded-2xl border border-white/[0.06] bg-white/[0.015] p-8 md:p-12 mb-8 relative overflow-hidden">
				<div class="absolute top-0 right-0 w-[300px] h-[300px] bg-teal-400/[0.05] rounded-full blur-3xl pointer-events-none"></div>
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center relative z-10">
					<div>
						<h3 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight">
							Su empresa <p class="text-teal-300 text-3xl md:text-4xl mt-2">potenciada con IA</p>
						</h3>
						<p class="text-gray-400 mb-6 leading-relaxed">
							Cada proyecto que desarrollamos evalúa oportunidades reales de automatización con IA: desde chatbots de atención al cliente hasta sistemas de recomendación de productos y análisis predictivo de ventas.
						</p>
						<ul class="space-y-3">
							<li class="flex items-center gap-3 text-gray-300 text-sm">
								<div class="w-1.5 h-1.5 rounded-full bg-teal-400 flex-shrink-0"></div>
								Automatización de flujos de trabajo internos
							</li>
							<li class="flex items-center gap-3 text-gray-300 text-sm">
								<div class="w-1.5 h-1.5 rounded-full bg-teal-400 flex-shrink-0"></div>
								Personalización inteligente de contenido
							</li>
							<li class="flex items-center gap-3 text-gray-300 text-sm">
								<div class="w-1.5 h-1.5 rounded-full bg-teal-400 flex-shrink-0"></div>
								Análisis de datos en tiempo real
							</li>
							<li class="flex items-center gap-3 text-gray-300 text-sm">
								<div class="w-1.5 h-1.5 rounded-full bg-teal-400 flex-shrink-0"></div>
								Integración con modelos de lenguaje (LLMs)
							</li>
						</ul>
					</div>
					<!-- Visual accent -->
					<div class="flex items-center justify-center">
						<div class="relative w-48 h-48 md:w-64 md:h-64">
							<!-- Outer ring -->
							<div class="absolute inset-0 rounded-full border border-teal-400/20 animate-spin" style="animation-duration: 12s;"></div>
							<!-- Middle ring -->
							<div class="absolute inset-4 rounded-full border border-teal-400/10 animate-spin" style="animation-duration: 8s; animation-direction: reverse;"></div>
							<!-- Center icon -->
							<div class="absolute inset-0 flex items-center justify-center">
								<div class="ia-badge w-24 h-24 md:w-32 md:h-32 rounded-full border border-teal-400/30 flex items-center justify-center">
									<svg class="w-10 h-10 md:w-14 md:h-14 text-teal-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
									</svg>
								</div>
							</div>
							<!-- Floating dots -->
							<div class="absolute top-2 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-teal-400/60"></div>
							<div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-teal-400/40"></div>
							<div class="absolute left-2 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-teal-400/50"></div>
							<div class="absolute right-2 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-teal-400/30"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- Feature cards grid -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Card 1 -->
				<div class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3v-3z"/>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">Chatbots Inteligentes</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Asistentes virtuales entrenados con el conocimiento de tu empresa para atender clientes 24/7 sin intervención humana.</p>
				</div>

				<!-- Card 2 -->
				<div class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">Automatización con Datos</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Dashboards y reportes automáticos que interpretan tu información y sugieren acciones concretas para crecer.</p>
				</div>

				<!-- Card 3 -->
				<div class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">Integración a Medida</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Conectamos APIs de IA (OpenAI, Anthropic, Google) directamente en tu plataforma con arquitectura robusta y escalable.</p>
				</div>
			</div>
		</div>
	</section>
	<div class="section-divider-gradient"></div>

	<!-- CTA Section - Explore More -->
	<section id="explorar" class="relative py-20 md:py-32 overflow-hidden scroll-mt-20 md:scroll-mt-24">
		<div class="absolute inset-0">
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-teal-400/5 rounded-full blur-3xl"></div>
		</div>

		<div class="container mx-auto max-w-7xl px-4 relative z-10">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
					Descubre Todo lo que <span class="text-teal-300">Podemos Hacer</span>
				</h2>
				<p class="text-xl text-gray-400 max-w-3xl mx-auto mb-12">
					Desde sitios web corporativos hasta tiendas en línea completas, tenemos la solución perfecta para tu negocio
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<!-- Services Card -->
				<a href="/servicios" class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">Servicios</h3>
					<p class="text-gray-400 text-sm">Desarrollo web completo y soluciones digitales</p>
				</a>

				<!-- E-commerce Card -->
				<a href="/ecommerce" class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">E-commerce</h3>
					<p class="text-gray-400 text-sm">Tiendas online que convierten visitantes en clientes</p>
				</a>

				<!-- Testimonials Card -->
				<a href="/testimonios" class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2 group-hover:text-teal-300 transition-colors">Testimonios</h3>
					<p class="text-gray-400 text-sm">Casos de éxito de nuestros clientes</p>
				</a>

				<!-- Contact Card -->
				<a href="/contacto" class="group p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] hover:border-teal-400/30 transition-all duration-300">
					<div class="w-12 h-12 rounded-xl mb-4 flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent group-hover:from-[#4CD6C0]/30 transition-all">
						<svg class="w-6 h-6 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
					</div>
