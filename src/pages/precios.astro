---
import Layout from '../layouts/Layout.astro';
import Pricing from '../components/Pricing.astro';
import ContactForm from '../components/contact-form/ContactForm';
import SpeedInsights from "@vercel/speed-insights/astro"
import Analytics from '@vercel/analytics/astro'
---

<style>
	.section-divider-gradient {
		position: relative;
		padding: 0;
		margin: 0;
		min-height: 1px;
		contain: layout style paint;
	}

	.section-divider-gradient::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 1400px;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(76, 214, 192, 0.1) 15%,
			rgba(76, 214, 192, 0.2) 50%,
			rgba(76, 214, 192, 0.1) 85%,
			transparent 100%
		);
		will-change: auto;
	}

	.section-divider-border {
		border-top: 1px solid rgba(255, 255, 255, 0.03);
		box-shadow:
			0 1px 0 rgba(76, 214, 192, 0.05),
			0 -1px 40px rgba(76, 214, 192, 0.02);
		min-height: 1px;
		contain: layout style paint;
	}

	.section-divider-bg-shift {
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(76, 214, 192, 0.008) 50%,
			transparent 100%
		);
		padding: 80px 0;
		contain: layout style;
	}

	.section-divider-glow {
		position: relative;
		padding-top: 1px;
		min-height: 120px;
		contain: layout style paint;
	}

	.section-divider-glow::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) translateZ(0);
		width: 100%;
		max-width: 800px;
		height: 120px;
		background: radial-gradient(
			ellipse at top,
			rgba(76, 214, 192, 0.08) 0%,
			rgba(76, 214, 192, 0.03) 30%,
			transparent 70%
		);
		pointer-events: none;
		will-change: auto;
	}

	.page-hero {
		position: relative;
		padding: 140px 0 80px;
		background: linear-gradient(to bottom, rgba(76, 214, 192, 0.05) 0%, transparent 100%);
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 120px 0 60px;
		}
	}

	.page-hero::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(
			ellipse at center,
			rgba(76, 214, 192, 0.15) 0%,
			transparent 70%
		);
		pointer-events: none;
	}
</style>

<Layout
	title="Precios y Planes | Kreadium - Cotiza tu Proyecto Web"
	description="Planes desde $150.900. Landing pages, sitios corporativos y tiendas e-commerce. Hosting incluido, SSL gratis, soporte 24/7. Sin costos ocultos."
	ogTitle="Precios y Planes | Kreadium - Cotiza tu Proyecto Web"
	ogDescription="Planes desde $150.900. Landing pages, sitios corporativos y tiendas e-commerce. Hosting incluido, SSL gratis, soporte 24/7. Sin costos ocultos."
	canonical="/precios"
>
	<!-- Structured Data - BreadcrumbList Schema -->
	<script is:inline type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://kreadium.cl/" },
			{ "@type": "ListItem", "position": 2, "name": "Precios", "item": "https://kreadium.cl/precios" }
		]
	}
	</script>

	<!-- Structured Data - Pricing/Offers Schema -->
	<script is:inline type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "ItemList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"item": {
					"@type": "Product",
					"name": "Landing Marketing",
					"description": "Una landing page de marketing enfocada en conversión: presenta tu producto o servicio y guía al visitante a una acción. Incluye asesoría de hosting y dominio. Factura con detalle neto $150.900 + IVA $28.671. Valor total $179.571.",
					"offers": {
						"@type": "Offer",
						"price": "179571",
						"priceCurrency": "CLP",
						"availability": "https://schema.org/InStock",
						"seller": {
							"@type": "Organization",
							"name": "Kreadium SpA"
						}
					}
				}
			},
			{
				"@type": "ListItem",
				"position": 2,
				"item": {
					"@type": "Product",
					"name": "Plan Pyme",
					"description": "Sitio web corporativo de hasta 7 secciones, SEO avanzado y soporte prioritario. Diseñado para pymes que adjudican capitales del Estado y fondos concursables (Sercotec, FOSIS, CORFO). Factura con detalle neto $450.900 + IVA $85.671. Valor total $536.571.",
					"offers": {
						"@type": "Offer",
						"price": "536571",
						"priceCurrency": "CLP",
						"availability": "https://schema.org/InStock",
						"seller": {
							"@type": "Organization",
							"name": "Kreadium SpA"
						}
					}
				}
			},
			{
				"@type": "ListItem",
				"position": 3,
				"item": {
					"@type": "Product",
					"name": "Plan E-commerce",
					"description": "Tienda online completa en Shopify para vender productos, cobrar en línea y gestionar pedidos y envíos. Incluye pasarela de pago y capacitación. Factura con detalle neto $1.199.900 + IVA $227.981. Valor total $1.427.881.",
					"offers": {
						"@type": "Offer",
						"price": "1427881",
						"priceCurrency": "CLP",
						"availability": "https://schema.org/InStock",
						"seller": {
							"@type": "Organization",
							"name": "Kreadium SpA"
						}
					}
				}
			}
		]
	}
	</script>

	<!-- Gradient divider -->
	<div class="section-divider-gradient"></div>

	<!-- Pricing Section -->
	<div class="section-divider-bg-shift">
		<Pricing />
	</div>

	<!-- Border divider -->
	<div class="section-divider-border"></div>

	<!-- FAQ Section -->
	<section id="faq" class="relative py-20 md:py-28 scroll-mt-20 md:scroll-mt-24">
		<div class="container mx-auto max-w-4xl px-6">
			<div class="text-center mb-16">
				<h2 class="font-geist text-3xl md:text-5xl font-bold text-white mb-6 tracking-[-0.025em] leading-[1.1]">
					Preguntas <span class="italic">Frecuentes</span>
				</h2>
				<p class="text-lg text-gray-400">
					Respuestas a las consultas más comunes sobre nuestros servicios
				</p>
			</div>

			<div class="space-y-6">
				<!-- FAQ Item -->
				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Por qué los precios muestran el neto, el IVA y el total por separado?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						Porque los capitales del Estado y fondos concursables en Chile (como Sercotec Capital Semilla, FOSIS y CORFO) entregan el subsidio en <strong class="text-gray-300">valor neto</strong>: el monto adjudicado <strong class="text-gray-300">no cubre el IVA del 19%</strong>. Por bases, los impuestos del proyecto son de cargo del beneficiario.<br><br>
						Por eso desglosamos cada plan: el <strong class="text-gray-300">neto</strong> es lo que normalmente financia el capital del Estado, y el <strong class="text-gray-300">IVA (19%)</strong> es el aporte que pone el emprendedor de su propio bolsillo. Así sabes con claridad qué cubre el fondo y qué debes financiar tú. Como beneficiario formal, ese IVA además queda como <strong class="text-gray-300">crédito fiscal</strong> a favor de tu empresa.
					</p>
				</details>

				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Cuánto tiempo toma desarrollar un sitio web?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						Un sitio web corporativo toma entre 2-4 semanas según el contenido. Una tienda e-commerce puede tomar de 4-8 semanas dependiendo de la complejidad y funcionalidades requeridas.
						Las landing pages se entregan en 1-2 semanas. <br>
						Siempre nos esforzamos por cumplir los plazos acordados y mantener una comunicación fluida durante todo el proceso.
					</p>
				</details>

				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Incluye hosting y dominio?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						No, Pero te ayudamos a elegir el mejor proveedor de hosting y dominio según tus necesidades. Ofrecemos asesoría personalizada para configurar tu hosting, instalar SSL y asegurarnos de que tu sitio esté seguro y optimizado desde el primer día.
					</p>
				</details>

				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Ofrecen soporte post-lanzamiento?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						Absolutamente. Incluimos 30 días de soporte gratuito post-lanzamiento. También ofrecemos planes de mantenimiento mensual para actualizaciones y mejoras continuas.
					</p>
				</details>

				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Puedo actualizar mi sitio después?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						Por supuesto. Nuestras soluciones son escalables. Puedes comenzar con un sitio básico y agregar funcionalidades como e-commerce, integraciones o secciones adicionales cuando lo necesites.
					</p>
				</details>

				<details class="group p-6 rounded-xl border border-white/[0.05] bg-white/[0.01] hover:bg-white/[0.03] transition-all">
					<summary class="cursor-pointer text-lg font-semibold text-white flex items-center justify-between">
						¿Qué métodos de pago aceptan?
						<svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
						</svg>
					</summary>
					<p class="mt-4 text-gray-400 leading-relaxed">
						Aceptamos transferencias bancarias, tarjetas de crédito/débito vía Flow, y podemos ofrecer planes de pago fraccionado para proyectos grandes.
					</p>
				</details>
			</div>
		</div>
	</section>

	<!-- Gradient divider -->
	<div class="section-divider-gradient"></div>

	<!-- Contact Form Section -->
	<div class="section-divider-glow">
		<ContactForm client:only />
	</div>

	<SpeedInsights />
	<Analytics />
</Layout>
