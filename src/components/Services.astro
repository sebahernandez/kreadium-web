---
// Minimal, professional, Vercel-inspired design
---

<style>
  /* Vercel-inspired minimal animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }

  .service-card {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(76, 214, 192, 0.4);
  }

  .stat-item {
    transition: transform 0.2s ease;
  }

  .stat-item:hover {
    transform: translateY(-2px);
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, #a0a0a0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: inherit;
    -webkit-font-synthesis: weight;
    font-synthesis: weight;
  }

  .accent-gradient {
    background: linear-gradient(135deg, #4CD6C0 0%, #09b397 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: inherit;
    -webkit-font-synthesis: weight;
    font-synthesis: weight;
  }

  /* Mobile fix: Use solid colors instead of gradients to preserve font-weight */
  @media (max-width: 768px) {
    .gradient-text {
      -webkit-text-fill-color: currentColor;
      background: none;
      -webkit-background-clip: unset;
      background-clip: unset;
      color: #e5e5e5;
    }

    .accent-gradient {
      -webkit-text-fill-color: currentColor;
      background: none;
      -webkit-background-clip: unset;
      background-clip: unset;
      color: #4CD6C0;
    }
  }
</style>

<section class="relative py-20 md:py-28" id="services">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#4CD6C0]/5 to-transparent pointer-events-none"></div>

  <div class="container mx-auto max-w-7xl px-6 relative z-10">

    <!-- Stats Grid - Vercel Style -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-28 max-w-5xl mx-auto fade-in">
      <div class="stat-item text-center p-6 rounded-xl bg-white/[0.02] border border-white/[0.05]">
        <div class="text-3xl md:text-4xl font-bold mb-2 accent-gradient">100%</div>
        <div class="text-sm text-gray-400">Responsive</div>
      </div>
      <div class="stat-item text-center p-6 rounded-xl bg-white/[0.02] border border-white/[0.05]">
        <div class="text-3xl md:text-4xl font-bold mb-2 accent-gradient">24/7</div>
        <div class="text-sm text-gray-400">Soporte</div>
      </div>
      <div class="stat-item text-center p-6 rounded-xl bg-white/[0.02] border border-white/[0.05]">
        <div class="text-3xl md:text-4xl font-bold mb-2 accent-gradient">SSL</div>
        <div class="text-sm text-gray-400">Seguro</div>
      </div>
      <div class="stat-item text-center p-6 rounded-xl bg-white/[0.02] border border-white/[0.05]">
        <div class="text-3xl md:text-4xl font-bold mb-2 accent-gradient">SEO</div>
        <div class="text-sm text-gray-400">Optimizado</div>
      </div>
    </div>

    <!-- Included in every project - compact band -->
    <div class="mb-8 text-center fade-in">
      <h2 class="font-geist text-2xl md:text-3xl font-bold text-white mb-3 tracking-[-0.02em]">
        Incluido en <span class="italic">todos</span> nuestros proyectos
      </h2>
      <p class="text-base text-gray-400 max-w-2xl mx-auto">
        Sin costos ocultos: cada sitio que entregamos ya viene listo para funcionar y crecer.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 mb-28 fade-in">

      <!-- Incluido 1: Rendimiento -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">Carga rápida</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Sitios veloces y optimizados para no perder visitas.</p>
        </div>
      </div>

      <!-- Incluido 2: Correo corporativo -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">Correo corporativo</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Correo profesional con tu propio dominio.</p>
        </div>
      </div>

      <!-- Incluido 3: Hosting + dominio -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">Hosting y dominio</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Configuramos todo por ti, sin que te compliques.</p>
        </div>
      </div>

      <!-- Incluido 4: Analítica -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">Analítica web</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Google Analytics para medir tus visitas y ventas.</p>
        </div>
      </div>

      <!-- Incluido 5: WhatsApp -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4-.8L3 20l1.3-3.9A7.96 7.96 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">WhatsApp integrado</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Botón directo para que te contacten al instante.</p>
        </div>
      </div>

      <!-- Incluido 6: Respaldos -->
      <div class="service-card group flex items-start gap-4 p-6 rounded-2xl border border-white/[0.05] bg-white/[0.01]">
        <div class="w-11 h-11 flex-shrink-0 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#4CD6C0]/20 to-transparent">
          <svg class="w-5 h-5 text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-white mb-1">Respaldos y seguridad</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Copias de seguridad para dejar tu sitio protegido.</p>
        </div>
      </div>

    </div>

  </div>
</section>
