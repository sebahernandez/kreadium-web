                <th class="text-center py-5 px-6 bg-[rgba(76,214,192,0.05)]">
                  <div class="flex flex-col items-center gap-2">
                    <span class="text-[#4CD6C0] font-bold text-base md:text-lg">Plan Pyme</span>
                    <span class="text-gray-300 text-xs font-normal">Fondos concursables</span>
