            <Image src={logoSercotec} alt="Sercotec" width={56} height={56} format="webp" class="w-7 h-7 rounded-full object-contain bg-white p-0.5" loading="lazy" />
            <Image src={logoFosis} alt="FOSIS" width={56} height={56} format="webp" class="w-7 h-7 rounded-full object-contain bg-white p-0.5" loading="lazy" />
            <Image src={logoCorfo} alt="CORFO" width={56} height={56} format="webp" class="w-7 h-7 rounded-full object-contain bg-white p-0.5" loading="lazy" />
          </div>
          <p class="text-xs text-gray-400">Compatible con Sercotec, FOSIS, CORFO y otros fondos concursables</p>
        </div>

        <a href="/contacto"
