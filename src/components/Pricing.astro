---
// Vercel-inspired minimal Pricing component with detailed comparison
import { Image } from 'astro:assets';
import logoSercotec from '../assets/logos/sercotec.png';
import logoFosis from '../assets/logos/fosis.png';
import logoCorfo from '../assets/logos/corfo.png';
---

<style>
  /* Vercel-inspired minimal animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }

  .pricing-card {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .pricing-card:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(76, 214, 192, 0.3);
    transform: translateY(-2px);
  }

  .popular-card {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .popular-card:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(76, 214, 192, 0.5);
    transform: translateY(-2px);
  }

  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, #a0a0a0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: inherit;
    -webkit-font-synthesis: weight;
    font-synthesis: weight;
  }

  .accent-gradient {
    background: linear-gradient(135deg, #4CD6C0 0%, #09b397 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: inherit;
    -webkit-font-synthesis: weight;
    font-synthesis: weight;
  }

  /* Mobile fix: Use solid colors instead of gradients to preserve font-weight */
  @media (max-width: 768px) {
    .gradient-text {
      -webkit-text-fill-color: currentColor;
      background: none;
      -webkit-background-clip: unset;
      background-clip: unset;
      color: #e5e5e5;
    }

    .accent-gradient {
      -webkit-text-fill-color: currentColor;
      background: none;
      -webkit-background-clip: unset;
      background-clip: unset;
      color: #4CD6C0;
    }
  }
</style>

<section class="relative py-20 md:py-28" id="pricing">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#4CD6C0]/5 to-transparent pointer-events-none"></div>

  <div class="container mx-auto max-w-7xl px-6 relative z-10">

    <!-- Header Section -->
    <div class="max-w-3xl mx-auto text-center mb-20 md:mb-28 fade-in">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6"
           style="background: rgba(76, 214, 192, 0.1); border: 1px solid rgba(76, 214, 192, 0.2); color: rgba(76, 214, 192, 0.9);">
        Precios
      </div>

      <h2 class="font-geist text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-[1.1] tracking-[-0.03em] text-white">
        Precios convenientes<br />
        <span class="gradient-text italic">para cada negocio</span>
      </h2>

      <p class="text-lg md:text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto">
        Hosting incluido, soporte continuo y actualizaciones.
        Sin costos ocultos.
      </p>
    </div>

    <!-- Pricing Cards - 3 Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto mb-20 md:mb-28">

      <!-- Landing Plan -->
      <div class="pricing-card p-8 rounded-2xl border border-white/[0.05] bg-white/[0.01] fade-in flex flex-col">
        <div class="mb-6">
          <h3 class="text-xl font-semibold text-white mb-2">Landing Marketing</h3>
