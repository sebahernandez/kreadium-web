        </div>

        <div class="mb-8">
          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-gray-400 text-sm">Valor total factura</span>
          </div>
          <div class="flex flex-col gap-1 mb-3">
            <span class="text-5xl font-bold text-white">$179.571</span>
            <span class="text-gray-400 text-sm">(pago único · IVA incluido)</span>
          </div>

          <!-- Detalle de montos -->
          <div class="rounded-lg border border-white/[0.08] bg-white/[0.02] p-3 mb-3">
            <p class="text-[11px] uppercase tracking-wide text-gray-400 font-semibold mb-2">Detalle de montos</p>
            <div class="space-y-1.5 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-400">Neto</span>
                <span class="text-white font-medium">$150.900</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-400">IVA 19%</span>
                <span class="text-white font-medium">$28.671</span>
              </div>
              <div class="flex justify-between pt-1.5 border-t border-white/[0.08]">
                <span class="text-gray-300 font-semibold">Total factura</span>
                <span class="text-white font-bold">$179.571</span>
              </div>
            </div>
          </div>

          <p class="text-xs text-gray-500">Ideal para captar clientes potenciales</p>
        </div>

        <ul class="space-y-4 mb-8 flex-grow">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#4CD6C0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-sm text-gray-300">1 landing page optimizada</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#4CD6C0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-sm text-gray-300">Asesoría en hosting y dominio</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#4CD6C0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
