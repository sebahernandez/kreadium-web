              <!-- Dominio + Configuración de cuentas -->
              <tr class="hover:bg-[rgba(76,214,192,0.04)] transition-colors">
                <td class="py-4 px-6 text-gray-200 text-sm md:text-base">Configuración de dominio + configuración de cuentas (Google Workspace, Zoho, etc.)</td>
                <td class="text-center py-4 px-6">
                  <svg class="w-6 h-6 mx-auto text-[#4CD6C0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
